# ========================================
# WEALTHCON PRODUCTION ENVIRONMENT TEMPLATE
# ========================================
# This is a template file - DO NOT commit actual secrets to version control
# Copy this to .env.production and fill in actual values
# ========================================

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/wealthcon

# AWS Configuration
AWS_CLOUDFRONT_URL=https://your-cloudfront-domain.cloudfront.net
AWS_S3_BUCKET_NAME=wealthcon-production-bucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_ENDPOINT=

# Redis Configuration
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_TOKEN_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRATION=86400

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@wealthcon.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@wealthcon.com
SUPPORT_EMAIL=support@wealthcon.com

# Application
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_HOST=https://your-production-domain.com
NEXT_PUBLIC_ITEM_PER_PAGE=10

# Logging
LOG_LEVEL=info
DEBUG=false

# Security
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Features
ENABLE_HLS_CONVERSION=true
ENABLE_COMMENT_MODERATION=true
ENABLE_ANALYTICS=true
ENABLE_BANNER_IMAGE=true

# File Limits (bytes)
MAX_VIDEO_SIZE=524288000
MAX_IMAGE_SIZE=10485760
MAX_DOCUMENT_SIZE=52428800

# Backup
DB_BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
