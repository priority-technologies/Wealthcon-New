# ========================================
# WEALTHCON PRODUCTION ENVIRONMENT
# ========================================
# This file contains all production configurations
# Keep this file secure and never commit sensitive values to public repos
# ========================================

# ========================================
# DATABASE CONFIGURATION
# ========================================
# MongoDB connection string for production database
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
# Or: mongodb://host:port/database (for self-hosted)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/wealthcon

# ========================================
# AWS S3 & CLOUDFRONT CONFIGURATION
# ========================================
# CloudFront distribution URL for serving uploaded content
# This is used to construct CDN URLs for videos, images, thumbnails
AWS_CLOUDFRONT_URL=https://your-cloudfront-domain.cloudfront.net

# S3 Bucket name for storing uploaded files
AWS_S3_BUCKET_NAME=wealthcon-production-bucket

# AWS Region where S3 bucket is located
AWS_REGION=us-east-1

# AWS IAM credentials (use IAM role for EC2/Lambda, not hardcoded keys in production)
# These should have S3 access permissions only
AWS_ACCESS_KEY_ID=your-production-access-key-id
AWS_SECRET_ACCESS_KEY=your-production-secret-access-key

# S3 endpoint (leave blank for standard AWS, use for self-hosted/MinIO)
AWS_ENDPOINT=

# ========================================
# REDIS CONFIGURATION
# ========================================
# Redis connection URL (primary method)
# Format: redis://[password@]host:port[/db]
# Examples:
#   redis://localhost:6379
#   redis://:password@redis-host.com:6379
#   rediss://redis-host.com:6379 (with TLS for production)
REDIS_URL=rediss://your-redis-password@your-redis-host.com:6379

# Redis host for BullMQ job queue (alternative to REDIS_URL)
# For AWS ElastiCache: your-elasticache-endpoint.cache.amazonaws.com
# For Redis Cloud: your-redis-cloud-endpoint.redis-cloud.com
# For self-hosted: your-redis-server-ip-or-domain
REDIS_HOST=your-redis-host.com

# Redis port (default: 6379)
REDIS_PORT=6379

# Redis password (if authentication enabled)
# Leave empty if no password required
REDIS_PASSWORD=your-redis-password

# Redis database number (default: 0)
REDIS_DB=0

# ========================================
# JWT AUTHENTICATION
# ========================================
# Secret key for JWT token signing and verification
# Generate a strong random string (minimum 32 characters)
# Command: openssl rand -base64 32
JWT_TOKEN_SECRET=your-super-secret-jwt-token-key-minimum-32-characters-long

# JWT token expiration time (in seconds)
# Default: 86400 (24 hours) = 1 day
JWT_EXPIRATION=86400

# ========================================
# EMAIL CONFIGURATION
# ========================================
# SMTP server for sending emails (user notifications, password reset, etc)
# Common services: smtp.gmail.com, smtp.sendgrid.net, smtp.mailgun.org
SMTP_HOST=smtp.gmail.com

# SMTP port (usually 587 for TLS or 465 for SSL)
SMTP_PORT=587

# SMTP username (usually your email address)
SMTP_USER=noreply@wealthcon.com

# SMTP password (use app-specific password if using Gmail)
SMTP_PASS=your-app-specific-email-password

# Email to send from (sender address)
SMTP_FROM_EMAIL=noreply@wealthcon.com

# Email to send support emails to
SUPPORT_EMAIL=support@wealthcon.com

# ========================================
# NEXT.JS APPLICATION CONFIGURATION
# ========================================
# Node environment (production, development, test)
NODE_ENV=production

# Application port
PORT=3000

# Public host URL (used for API calls from client, OAuth redirects, etc)
# This is the public-facing URL of your application
NEXT_PUBLIC_HOST=https://your-production-domain.com

# Items per page for pagination (in admin and user listings)
NEXT_PUBLIC_ITEM_PER_PAGE=10

# ========================================
# LOGGING & MONITORING
# ========================================
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable debug mode (set to false in production)
DEBUG=false

# ========================================
# SECURITY HEADERS
# ========================================
# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://your-production-domain.com,https://www.your-production-domain.com

# ========================================
# OPTIONAL: EXTERNAL SERVICES
# ========================================
# Sentry error tracking (optional)
# SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=UA-XXXXXXXX-X

# ========================================
# VIDEO CONVERSION
# ========================================
# Enable HLS video conversion (requires FFmpeg on server)
ENABLE_HLS_CONVERSION=true

# Maximum concurrent video conversions
MAX_CONVERSION_CONCURRENCY=2

# Video conversion timeout (in seconds)
VIDEO_CONVERSION_TIMEOUT=3600

# ========================================
# FEATURE FLAGS
# ========================================
# Enable comment moderation feature
ENABLE_COMMENT_MODERATION=true

# Enable analytics tracking
ENABLE_ANALYTICS=true

# Enable banner image feature
ENABLE_BANNER_IMAGE=true

# ========================================
# FILE UPLOAD LIMITS
# ========================================
# Maximum file size for video uploads (in bytes) - 500MB
MAX_VIDEO_SIZE=524288000

# Maximum file size for image uploads (in bytes) - 10MB
MAX_IMAGE_SIZE=10485760

# Maximum file size for document uploads (in bytes) - 50MB
MAX_DOCUMENT_SIZE=52428800

# ========================================
# BACKUP & MAINTENANCE
# ========================================
# Database backup schedule (cron format)
# 0 2 * * * = Every day at 2 AM
DB_BACKUP_SCHEDULE=0 2 * * *

# Backup retention days (keep backups for X days)
BACKUP_RETENTION_DAYS=30

# ========================================
# END OF PRODUCTION CONFIGURATION
# ========================================
